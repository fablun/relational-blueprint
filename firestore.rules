rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users: readable by self, writable by self
    match /users/{userId} {
      allow read:  if request.auth != null &&
                     (request.auth.uid == userId ||
                      // partner can read your profile
                      resource.data.partnerId == request.auth.uid ||
                      request.auth.uid in resource.data.keys());
      allow write: if request.auth != null && request.auth.uid == userId;

      // Allow partner to read testResults for couple report
      allow read: if request.auth != null;
    }

    // Couples: readable/writable by the two users in the couple
    match /couples/{coupleId} {
      allow read, write: if request.auth != null &&
        request.auth.uid in resource.data.users;

      // Allow creation
      allow create: if request.auth != null &&
        request.auth.uid in request.resource.data.users;
    }
  }
}
