{
  "buildCommand": "node build.js",
  "outputDirectory": ".",
  "rewrites": [
    { "source": "/((?!js|data|assets|style\\.css|firebase-config\\.js|build\\.js|package\\.json).*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" }
      ]
    }
  ]
}
